generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String?
  password     String
  role         Role      @default(USER)
  refreshToken String?
  emailOTP     String?
  phoneOTP     String?
  otpExpiry    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  todos       Todo[]
  busBookings BusBooking[]
}

enum Role {
  USER
  ADMIN
  MANAGER
}

model Todo {
  id        String    @id @default(uuid())
  userId    String
  todo      String
  completed Boolean   @default(false)
  dueDate   DateTime?
  priority  Priority  @default(medium)
  tags      String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum Priority {
  low
  medium
  high
}

model Booking {
  id            String   @id @default(uuid())
  passengerName String
  from          String
  to            String
  travelDate    DateTime
  seatNumber    Int
  price         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BusVendor {
  id        String   @id @default(uuid())
  name      String
  contact   String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules BusSchedule[]
}

model BusLocation {
  id         String   @id @default(uuid())
  locationId Int?     @unique
  city       String
  state      String
  address    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sourceSchedules      BusSchedule[] @relation("SourceLocation")
  destinationSchedules BusSchedule[] @relation("DestinationLocation")
}

model BusSchedule {
  id                    String   @id @default(uuid())
  busName               String
  vendorId              String
  sourceLocationId      String
  destinationLocationId String
  departureTime         DateTime
  arrivalTime           DateTime
  price                 Float
  scheduleDate          DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  vendor      BusVendor    @relation(fields: [vendorId], references: [id])
  source      BusLocation  @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destination BusLocation  @relation("DestinationLocation", fields: [destinationLocationId], references: [id])
  bookings    BusBooking[]
}

model BusBooking {
  id          String           @id @default(uuid())
  userId      String
  scheduleId  String
  seatNumbers Int[]
  status      BusBookingStatus @default(BOOKED)
  totalAmount Float
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  schedule BusSchedule @relation(fields: [scheduleId], references: [id])
}

enum BusBookingStatus {
  BOOKED
  CANCELLED
}

model UserData {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  maidenName String?
  age        Int?
  gender     String?
  username   String
  password   String?
  email      String
  phone      String?
  birthDate  String?
  image      String?
  bloodGroup String?
  height     Float?
  weight     Float?
  eyeColor   String?
  hair       Json? // { color: string, type: string }
  ip         String?
  address    Json? // Full address object
  macAddress String?
  university String?
  bank       Json? // Bank details
  company    Json? // Company details
  ein        String?
  ssn        String?
  userAgent  String?
  crypto     Json? // Crypto details
  role       String   @default("user")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
